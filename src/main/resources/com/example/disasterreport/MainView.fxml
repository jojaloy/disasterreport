<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.disasterreport.controller.MainController"
      spacing="0" style="-fx-background-color: #f4f5f7;">

    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #0f1623; -fx-padding: 15 28 15 28;" spacing="12">
        <Label text="⚠  Disaster Report System" style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="loggedInUserLabel" text="Logged in as: User" style="-fx-text-fill: #8fa3bc; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        <Button text="Log Out" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: rgba(255,255,255,0.4); -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 12px; -fx-padding: 5 14 5 14; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
    </HBox>

    <HBox VBox.vgrow="ALWAYS">
        <VBox spacing="4" style="-fx-background-color: #0f1623;" minWidth="205" maxWidth="205">
            <padding><Insets top="22" right="14" bottom="22" left="14"/></padding>

            <Label text="NAVIGATION" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-padding: 0 0 8 6; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>

            <Button fx:id="btnDashboard" text="Dashboard" maxWidth="Infinity" onAction="#showDashboard" style="-fx-background-color: #e8550a; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand; -fx-padding: 10 14 10 14; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Button fx:id="btnReportIncident" text="Report Incident" maxWidth="Infinity" onAction="#showReportForm" style="-fx-background-color: transparent; -fx-text-fill: #b0c4d8; -fx-alignment: CENTER_LEFT; -fx-font-size: 13px; -fx-background-radius: 7; -fx-cursor: hand; -fx-padding: 10 14 10 14; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Button fx:id="btnMapView" text="Incidents &amp; Map" maxWidth="Infinity" onAction="#showMapView" style="-fx-background-color: transparent; -fx-text-fill: #b0c4d8; -fx-alignment: CENTER_LEFT; -fx-font-size: 13px; -fx-background-radius: 7; -fx-cursor: hand; -fx-padding: 10 14 10 14; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Button fx:id="btnProfile" text="My Profile" maxWidth="Infinity" onAction="#showProfile" style="-fx-background-color: transparent; -fx-text-fill: #b0c4d8; -fx-alignment: CENTER_LEFT; -fx-font-size: 13px; -fx-background-radius: 7; -fx-cursor: hand; -fx-padding: 10 14 10 14; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>

            <Region minHeight="15"/>
            <Label fx:id="adminLabel" text="ADMINISTRATION" visible="false" managed="false" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-padding: 0 0 8 6; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Button fx:id="btnManageUsers" text="Manage Users" maxWidth="Infinity" onAction="#showManageUsers" visible="false" managed="false" style="-fx-background-color: transparent; -fx-text-fill: #b0c4d8; -fx-alignment: CENTER_LEFT; -fx-font-size: 13px; -fx-background-radius: 7; -fx-cursor: hand; -fx-padding: 10 14 10 14; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Button fx:id="btnRequestRole" text="Request Role Change" maxWidth="Infinity" onAction="#handleRequestRole" visible="false" managed="false" style="-fx-background-color: transparent; -fx-text-fill: #b0c4d8; -fx-alignment: CENTER_LEFT; -fx-font-size: 13px; -fx-background-radius: 7; -fx-cursor: hand; -fx-padding: 10 14 10 14; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="8" style="-fx-padding: 0 0 8 6;">
                <Label text="SYSTEM STATUS" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #4a6080; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Total Reports" style="-fx-font-size: 12px; -fx-text-fill: #8fa3bc; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalIncidentsLabel" text="0" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Active" style="-fx-font-size: 12px; -fx-text-fill: #8fa3bc; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="activeIncidentsLabel" text="0" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #e8550a;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Resolved" style="-fx-font-size: 12px; -fx-text-fill: #8fa3bc; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="resolvedIncidentsLabel" text="0" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #16a34a;"/>
                </HBox>
            </VBox>
        </VBox>

        <VBox fx:id="contentArea" HBox.hgrow="ALWAYS" style="-fx-background-color: white;"/>
    </HBox>

    <HBox style="-fx-background-color: #f0f2f5; -fx-border-color: #e2e5ea; -fx-border-width: 1 0 0 0; -fx-padding: 5 14 5 14;">
        <Label fx:id="statusLabel" text="Ready" style="-fx-font-size: 11px; -fx-text-fill: #6b7280; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
    </HBox>
</VBox>