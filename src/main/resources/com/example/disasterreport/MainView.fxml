<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.disasterreport.controller.MainController"
      spacing="0"
      style="-fx-background-color: #f0f2f5;">

    <!-- ── Top Navigation Bar ── -->
    <HBox alignment="CENTER_LEFT"
          style="-fx-background-color: #1a2a4a; -fx-padding: 14 24 14 24;"
          spacing="12">
        <Label text="Disaster Report System"
               style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="loggedInUserLabel"
               text="Logged in as: User"
               style="-fx-text-fill: #b0bec5; -fx-font-size: 13px;"/>
        <Button text="Log Out"
                onAction="#handleLogout"
                style="-fx-background-color: transparent; -fx-text-fill: white;
                       -fx-border-color: white; -fx-border-radius: 4;
                       -fx-background-radius: 4; -fx-cursor: hand;
                       -fx-font-size: 13px; -fx-padding: 4 12 4 12;"/>
    </HBox>

    <!-- ── Body: Sidebar + Content ── -->
    <HBox VBox.vgrow="ALWAYS">

        <!-- Sidebar -->
        <VBox spacing="8"
              style="-fx-background-color: #f7f8fa;
                     -fx-border-color: #dde1e7;
                     -fx-border-width: 0 1 0 0;"
              minWidth="200" maxWidth="200">
            <padding><Insets top="20" right="12" bottom="20" left="12"/></padding>

            <Label text="NAVIGATION"
                   style="-fx-font-size: 11px; -fx-font-weight: bold;
                          -fx-text-fill: #9ca3af; -fx-padding: 0 0 6 4;"/>

            <Button text="Dashboard"       maxWidth="Infinity" onAction="#showDashboard"
                    style="-fx-background-color: #e8edf5; -fx-text-fill: #1a2a4a;
                           -fx-alignment: CENTER_LEFT; -fx-font-size: 13px;
                           -fx-background-radius: 5; -fx-cursor: hand;
                           -fx-padding: 9 12 9 12;"/>
            <Button text="Report Incident" maxWidth="Infinity" onAction="#showReportForm"
                    style="-fx-background-color: transparent; -fx-text-fill: #374151;
                           -fx-alignment: CENTER_LEFT; -fx-font-size: 13px;
                           -fx-background-radius: 5; -fx-cursor: hand;
                           -fx-padding: 9 12 9 12;"/>
            <Button text="Incident List"   maxWidth="Infinity" onAction="#showIncidentList"
                    style="-fx-background-color: transparent; -fx-text-fill: #374151;
                           -fx-alignment: CENTER_LEFT; -fx-font-size: 13px;
                           -fx-background-radius: 5; -fx-cursor: hand;
                           -fx-padding: 9 12 9 12;"/>
            <Button text="Generate Report" maxWidth="Infinity" onAction="#showReportGenerator"
                    style="-fx-background-color: transparent; -fx-text-fill: #374151;
                           -fx-alignment: CENTER_LEFT; -fx-font-size: 13px;
                           -fx-background-radius: 5; -fx-cursor: hand;
                           -fx-padding: 9 12 9 12;"/>
            <Button text="Map View" maxWidth="Infinity" onAction="#showMapView"
                    style="-fx-background-color: transparent; -fx-text-fill: #374151;
               -fx-alignment: CENTER_LEFT; -fx-font-size: 13px;
               -fx-background-radius: 5; -fx-cursor: hand;
               -fx-padding: 9 12 9 12;"/>
        </VBox>

        <!-- Main Content -->
        <VBox HBox.hgrow="ALWAYS" spacing="20">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <!-- Stats Cards -->
            <HBox spacing="16">
                <!-- Total Reports -->
                <VBox spacing="6"
                      style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-border-color: #dde1e7; -fx-border-radius: 8;
                             -fx-border-width: 1; -fx-padding: 20;"
                      HBox.hgrow="ALWAYS">
                    <Label text="Total Reports"
                           style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="totalIncidentsLabel" text="0"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1a2a4a;"/>
                </VBox>
                <!-- Active Incidents -->
                <VBox spacing="6"
                      style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-border-color: #dde1e7; -fx-border-radius: 8;
                             -fx-border-width: 1; -fx-padding: 20;"
                      HBox.hgrow="ALWAYS">
                    <Label text="Active Incidents"
                           style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="activeIncidentsLabel" text="0"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #dc2626;"/>
                </VBox>
                <!-- Resolved -->
                <VBox spacing="6"
                      style="-fx-background-color: white; -fx-background-radius: 8;
                             -fx-border-color: #dde1e7; -fx-border-radius: 8;
                             -fx-border-width: 1; -fx-padding: 20;"
                      HBox.hgrow="ALWAYS">
                    <Label text="Resolved"
                           style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="resolvedIncidentsLabel" text="0"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #16a34a;"/>
                </VBox>
            </HBox>

            <!-- Recent Incidents -->
            <VBox spacing="8"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #dde1e7; -fx-border-radius: 8;
                         -fx-border-width: 1; -fx-padding: 20;"
                  VBox.vgrow="ALWAYS">
                <Label text="Recent Incidents"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a2a4a;"/>

                <!-- Dynamic content loaded here -->
                <VBox fx:id="contentArea" VBox.vgrow="ALWAYS">
                    <Label text="No incidents reported yet."
                           style="-fx-font-size: 13px; -fx-text-fill: #9ca3af;"/>
                </VBox>
            </VBox>

        </VBox>
    </HBox>

    <!-- Status Bar -->
    <HBox style="-fx-background-color: #e8eaed; -fx-padding: 4 12 4 12;">
        <Label fx:id="statusLabel" text="Ready"
               style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
    </HBox>

</VBox>
