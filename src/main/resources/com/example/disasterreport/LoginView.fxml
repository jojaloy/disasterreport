<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.disasterreport.controller.LoginController"
      alignment="CENTER"
      spacing="0"
      style="-fx-background-color: #f4f5f7;">

    <HBox alignment="CENTER_LEFT"
          style="-fx-background-color: #0f1623; -fx-padding: 16 28 16 28;">
        <Label text="⚠  Disaster Report System"
               style="-fx-text-fill: white;
                      -fx-font-size: 17px;
                      -fx-font-weight: bold;
                      -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
    </HBox>

    <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
        <VBox maxWidth="400"
              spacing="0"
              style="-fx-background-color: white;
                     -fx-background-radius: 10;
                     -fx-border-color: #e2e5ea;
                     -fx-border-radius: 10;
                     -fx-border-width: 1;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 18, 0, 0, 4);">
            <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

            <Label text="Welcome Back"
                   style="-fx-font-size: 24px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #0f1623;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Region minHeight="4"/>
            <Label text="Sign in to your account to continue."
                   style="-fx-font-size: 13px;
                          -fx-text-fill: #6b7280;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>

            <Region minHeight="20"/>

            <Label text="Username"
                   style="-fx-font-size: 12px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #374151;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Region minHeight="5"/>
            <TextField fx:id="usernameField"
                       promptText="Enter username"
                       style="-fx-background-color: #f9fafb;
                              -fx-border-color: #d1d5db;
                              -fx-border-radius: 6;
                              -fx-background-radius: 6;
                              -fx-padding: 10 13 10 13;
                              -fx-font-size: 13px;
                              -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>

            <Region minHeight="14"/>

            <Label text="Password"
                   style="-fx-font-size: 12px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #374151;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Region minHeight="5"/>

            <StackPane alignment="CENTER_LEFT">
                <TextField fx:id="passwordTextField"
                           promptText="Enter password"
                           visible="false" managed="false"
                           style="-fx-background-color: #f9fafb;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-radius: 6;
                                  -fx-background-radius: 6;
                                  -fx-padding: 10 13 10 13;
                                  -fx-font-size: 13px;
                                  -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                <PasswordField fx:id="passwordField"
                               promptText="Enter password"
                               style="-fx-background-color: #f9fafb;
                                      -fx-border-color: #d1d5db;
                                      -fx-border-radius: 6;
                                      -fx-background-radius: 6;
                                      -fx-padding: 10 13 10 13;
                                      -fx-font-size: 13px;
                                      -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            </StackPane>

            <Region minHeight="8"/>

            <HBox alignment="CENTER_LEFT">
                <CheckBox fx:id="showPasswordCheckBox" text="Show Password"
                          onAction="#togglePasswordVisibility"
                          style="-fx-font-size: 12px;
                                 -fx-text-fill: #6b7280;
                                 -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Hyperlink text="Forgot Password?"
                           onAction="#handleForgotPassword"
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #e8550a;
                                  -fx-font-family: 'Segoe UI', 'Arial', sans-serif;
                                  -fx-padding: 0;
                                  -fx-border-color: transparent;"/>
            </HBox>

            <Label fx:id="errorLabel"
                   text=""
                   wrapText="true"
                   style="-fx-text-fill: #dc2626;
                          -fx-font-size: 12px;
                          -fx-padding: 8 0 0 0;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"
                   visible="false" managed="false"/>

            <Region minHeight="22"/>

            <Button fx:id="loginButton"
                    text="Log In"
                    maxWidth="Infinity"
                    onAction="#handleLogin"
                    style="-fx-background-color: #e8550a;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 6;
                           -fx-cursor: hand;
                           -fx-padding: 11 0 11 0;
                           -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>

            <Region minHeight="16"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="Don't have an account?"
                       style="-fx-font-size: 13px;
                              -fx-text-fill: #6b7280;
                              -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                <Hyperlink text="Register"
                           onAction="#handleGoToRegister"
                           style="-fx-font-size: 13px;
                                  -fx-text-fill: #e8550a;
                                  -fx-font-weight: bold;
                                  -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            </HBox>

        </VBox>
    </VBox>

    <HBox style="-fx-background-color: #e8eaed;
                 -fx-padding: 5 14 5 14;">
        <Label text="Ready"
               style="-fx-font-size: 11px;
                      -fx-text-fill: #6b7280;
                      -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
    </HBox>

</VBox>