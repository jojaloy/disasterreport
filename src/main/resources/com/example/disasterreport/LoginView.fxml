<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.disasterreport.controller.LoginController"
      alignment="CENTER"
      spacing="0"
      style="-fx-background-color: #0d1b2a;">

    <!-- Top accent bar -->
    <HBox alignment="CENTER_LEFT" minHeight="56"
          style="-fx-background-color: linear-gradient(to right, #0d1b2a, #1a3a5c);
                 -fx-padding: 0 28 0 0;
                 -fx-border-color: #1e3a5f;
                 -fx-border-width: 0 0 1 0;">
        <Rectangle width="4" height="56"
                   style="-fx-fill: linear-gradient(to bottom, #38bdf8, #0ea5e9);"/>
        <VBox spacing="1" style="-fx-padding: 0 0 0 18;">
            <Label text="DISASTER ALERT SYSTEM"
                   style="-fx-font-size: 14px; -fx-font-weight: bold;
                          -fx-text-fill: #f0f9ff; -fx-font-family: 'Segoe UI';
                          -fx-letter-spacing: 1.5;"/>
            <Label text="Emergency Incident Management"
                   style="-fx-font-size: 11px; -fx-text-fill: #38bdf8;
                          -fx-font-family: 'Segoe UI';"/>
        </VBox>
    </HBox>

    <!-- Login card -->
    <VBox alignment="CENTER" VBox.vgrow="ALWAYS"
          style="-fx-background-color: #0d1b2a;">

        <VBox maxWidth="420" spacing="0"
              style="-fx-background-color: #1a2f45;
                     -fx-background-radius: 16;
                     -fx-border-color: #1e3a5f;
                     -fx-border-radius: 16;
                     -fx-border-width: 1;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 32, 0, 0, 8);">

            <!-- Card header band -->
            <VBox style="-fx-background-color: #142033;
                         -fx-background-radius: 16 16 0 0;
                         -fx-padding: 26 30 22 30;
                         -fx-border-color: #1e3a5f;
                         -fx-border-width: 0 0 1 0;">
                <Label text="Sign In"
                       style="-fx-font-size: 24px; -fx-font-weight: bold;
                              -fx-text-fill: #f0f9ff; -fx-font-family: 'Segoe UI';"/>
                <Label text="Access the disaster monitoring dashboard."
                       style="-fx-font-size: 13px; -fx-text-fill: #64748b;
                              -fx-font-family: 'Segoe UI'; -fx-padding: 4 0 0 0;"/>
            </VBox>

            <!-- Form fields -->
            <VBox spacing="14" style="-fx-padding: 26 30 30 30;">

                <VBox spacing="6">
                    <Label text="USERNAME"
                           style="-fx-font-size: 10px; -fx-font-weight: bold;
                                  -fx-text-fill: #38bdf8; -fx-letter-spacing: 1.2;
                                  -fx-font-family: 'Segoe UI';"/>
                    <TextField fx:id="usernameField"
                               promptText="Enter your username"
                               style="-fx-background-color: #0f2233;
                                      -fx-border-color: #1e3a5f;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-text-fill: #f0f9ff;
                                      -fx-prompt-text-fill: #334155;
                                      -fx-padding: 11 14 11 14;
                                      -fx-font-size: 13px;
                                      -fx-font-family: 'Segoe UI';"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="PASSWORD"
                           style="-fx-font-size: 10px; -fx-font-weight: bold;
                                  -fx-text-fill: #38bdf8; -fx-letter-spacing: 1.2;
                                  -fx-font-family: 'Segoe UI';"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Enter your password"
                                   style="-fx-background-color: #0f2233;
                                          -fx-border-color: #1e3a5f;
                                          -fx-border-radius: 8;
                                          -fx-background-radius: 8;
                                          -fx-text-fill: #f0f9ff;
                                          -fx-prompt-text-fill: #334155;
                                          -fx-padding: 11 14 11 14;
                                          -fx-font-size: 13px;
                                          -fx-font-family: 'Segoe UI';"/>
                </VBox>

                <Label fx:id="errorLabel" text=""
                       wrapText="true"
                       style="-fx-text-fill: #fca5a5; -fx-font-size: 12px;
                              -fx-font-family: 'Segoe UI';
                              -fx-background-color: #450a0a;
                              -fx-background-radius: 6;
                              -fx-padding: 8 12 8 12;"
                       visible="false" managed="false"/>

                <Region minHeight="4"/>

                <Button fx:id="loginButton"
                        text="Sign In  →"
                        maxWidth="Infinity"
                        onAction="#handleLogin"
                        style="-fx-background-color: linear-gradient(to right, #0ea5e9, #38bdf8);
                               -fx-text-fill: #0d1b2a;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;
                               -fx-font-family: 'Segoe UI';
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-padding: 12 0 12 0;"/>

                <HBox alignment="CENTER" spacing="6">
                    <Label text="Don't have an account?"
                           style="-fx-font-size: 13px; -fx-text-fill: #64748b;
                                  -fx-font-family: 'Segoe UI';"/>
                    <Hyperlink text="Register here"
                               onAction="#handleGoToRegister"
                               style="-fx-font-size: 13px; -fx-text-fill: #38bdf8;
                                      -fx-font-weight: bold; -fx-font-family: 'Segoe UI';
                                      -fx-border-color: transparent;"/>
                </HBox>

            </VBox>
        </VBox>
    </VBox>

    <!-- Footer -->
    <HBox style="-fx-background-color: #0a1628;
                 -fx-border-color: #1e3a5f;
                 -fx-border-width: 1 0 0 0;
                 -fx-padding: 6 16 6 16;"
          alignment="CENTER_LEFT" spacing="8">
        <Label text="●" style="-fx-text-fill: #4ade80; -fx-font-size: 9px;"/>
        <Label text="System Ready"
               style="-fx-font-size: 11px; -fx-text-fill: #334155;
                      -fx-font-family: 'Segoe UI';"/>
    </HBox>

</VBox>
