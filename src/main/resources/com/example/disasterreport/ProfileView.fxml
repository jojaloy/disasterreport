<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f3f4f6;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.disasterreport.controller.ProfileController">

    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
        <Label text="My Profile" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
        <Separator/>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Username:" style="-fx-font-weight: bold; -fx-text-fill: #6b7280; -fx-min-width: 100;"/>
            <Label fx:id="lblUsername" text="---" style="-fx-font-size: 14px; -fx-text-fill: #111827;"/>
        </HBox>

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Current Role:" style="-fx-font-weight: bold; -fx-text-fill: #6b7280; -fx-min-width: 100;"/>
            <Label fx:id="lblRole" text="---" style="-fx-font-size: 14px; -fx-text-fill: #111827;"/>
        </HBox>

        <HBox fx:id="agencyContainer" spacing="15" alignment="CENTER_LEFT" managed="false" visible="false">
            <Label text="Department:" style="-fx-font-weight: bold; -fx-text-fill: #6b7280; -fx-min-width: 100;"/>
            <Label fx:id="lblAgency" text="---" style="-fx-font-size: 14px; -fx-text-fill: #e8550a; -fx-font-weight: bold;"/>
        </HBox>

        <HBox fx:id="trustContainer" spacing="15" alignment="CENTER_LEFT" managed="false" visible="false">
            <Label text="Trust Score:" style="-fx-font-weight: bold; -fx-text-fill: #6b7280; -fx-min-width: 100;"/>
            <Label fx:id="lblTrustScore" text="---" style="-fx-font-size: 14px; -fx-text-fill: #059669; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>

    <HBox spacing="20">
        <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
            <Label text="Change Password" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
            <Separator/>
            <PasswordField fx:id="txtNewPassword" promptText="Enter new password" style="-fx-padding: 8; -fx-border-color: #d1d5db; -fx-border-radius: 4;"/>
            <PasswordField fx:id="txtConfirmPassword" promptText="Confirm new password" style="-fx-padding: 8; -fx-border-color: #d1d5db; -fx-border-radius: 4;"/>
            <Button text="Update Password" onAction="#handleUpdatePassword" maxWidth="Infinity" style="-fx-background-color: #0f1623; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8;"/>
        </VBox>

        <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
            <Label text="Request Role Upgrade" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
            <Separator/>
            <ComboBox fx:id="comboRequestedRole" promptText="Select desired role" maxWidth="Infinity" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 4; -fx-padding: 4;"/>
            <TextField fx:id="txtReason" promptText="Reason for request (Optional)" style="-fx-padding: 8; -fx-border-color: #d1d5db; -fx-border-radius: 4;"/>
            <Button text="Submit Request" onAction="#handleSubmitRequest" maxWidth="Infinity" style="-fx-background-color: #e8550a; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8;"/>
        </VBox>
    </HBox>
</VBox>