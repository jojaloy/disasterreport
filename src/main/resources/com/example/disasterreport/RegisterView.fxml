<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.disasterreport.controller.RegisterController"
      alignment="CENTER"
      spacing="0"
      style="-fx-background-color: #f4f5f7;">

    <HBox alignment="CENTER_LEFT"
          style="-fx-background-color: #0f1623; -fx-padding: 16 28 16 28;">
        <Label text="⚠  Disaster Report System"
               style="-fx-text-fill: white;
                      -fx-font-size: 17px;
                      -fx-font-weight: bold;
                      -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
    </HBox>

    <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
        <VBox maxWidth="420"
              spacing="0"
              style="-fx-background-color: white;
                     -fx-background-radius: 10;
                     -fx-border-color: #e2e5ea;
                     -fx-border-radius: 10;
                     -fx-border-width: 1;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 18, 0, 0, 4);">
            <padding><Insets top="36" right="40" bottom="36" left="40"/></padding>

            <Label text="Create Account"
                   style="-fx-font-size: 24px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #0f1623;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Region minHeight="4"/>
            <Label text="Fill in your details to register."
                   style="-fx-font-size: 13px;
                          -fx-text-fill: #6b7280;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>

            <Region minHeight="20"/>

            <Label text="Full Name"
                   style="-fx-font-size: 12px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #374151;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Region minHeight="5"/>
            <TextField fx:id="fullNameField"
                       promptText="Enter your full name"
                       style="-fx-background-color: #f9fafb;
                              -fx-border-color: #d1d5db;
                              -fx-border-radius: 6;
                              -fx-background-radius: 6;
                              -fx-padding: 10 13 10 13;
                              -fx-font-size: 13px;
                              -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>

            <Region minHeight="12"/>

            <Label text="Username *"
                   style="-fx-font-size: 12px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #374151;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Region minHeight="5"/>
            <TextField fx:id="usernameField"
                       promptText="Choose a username"
                       style="-fx-background-color: #f9fafb;
                              -fx-border-color: #d1d5db;
                              -fx-border-radius: 6;
                              -fx-background-radius: 6;
                              -fx-padding: 10 13 10 13;
                              -fx-font-size: 13px;
                              -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>

            <Region minHeight="12"/>

            <Label text="Password *"
                   style="-fx-font-size: 12px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #374151;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Region minHeight="5"/>
            <PasswordField fx:id="passwordField"
                           promptText="Create a password"
                           style="-fx-background-color: #f9fafb;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-radius: 6;
                                  -fx-background-radius: 6;
                                  -fx-padding: 10 13 10 13;
                                  -fx-font-size: 13px;
                                  -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>

            <Region minHeight="12"/>

            <Label text="Confirm Password *"
                   style="-fx-font-size: 12px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #374151;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Region minHeight="5"/>
            <PasswordField fx:id="confirmPasswordField"
                           promptText="Re-enter your password"
                           style="-fx-background-color: #f9fafb;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-radius: 6;
                                  -fx-background-radius: 6;
                                  -fx-padding: 10 13 10 13;
                                  -fx-font-size: 13px;
                                  -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>

            <Region minHeight="10"/>

            <Label fx:id="validationLabel"
                   text=""
                   wrapText="true"
                   maxWidth="Infinity"
                   style="-fx-text-fill: #dc2626;
                          -fx-font-size: 12px;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"
                   visible="false" managed="false"/>

            <Label fx:id="successLabel"
                   text=""
                   wrapText="true"
                   maxWidth="Infinity"
                   style="-fx-text-fill: #16a34a;
                          -fx-font-size: 12px;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"
                   visible="false" managed="false"/>

            <Region minHeight="18"/>

            <Button text="Register"
                    maxWidth="Infinity"
                    onAction="#handleRegister"
                    style="-fx-background-color: #e8550a;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 6;
                           -fx-cursor: hand;
                           -fx-padding: 11 0 11 0;
                           -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>

            <Region minHeight="14"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="Already have an account?"
                       style="-fx-font-size: 13px;
                              -fx-text-fill: #6b7280;
                              -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                <Hyperlink text="Back to Login"
                           onAction="#handleBackToLogin"
                           style="-fx-font-size: 13px;
                                  -fx-text-fill: #e8550a;
                                  -fx-font-weight: bold;
                                  -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            </HBox>

        </VBox>
    </VBox>

    <HBox style="-fx-background-color: #e8eaed;
                 -fx-padding: 5 14 5 14;">
        <Label fx:id="statusLabel" text="Ready"
               style="-fx-font-size: 11px;
                      -fx-text-fill: #6b7280;
                      -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
    </HBox>

</VBox>