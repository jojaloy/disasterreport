<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.disasterreport.controller.ManageUsersController">

    <VBox spacing="0" style="-fx-background-color: white;">

        <VBox style="-fx-background-color: white; -fx-border-color: #e2e5ea; -fx-border-width: 0 0 1 0; -fx-padding: 18 26 18 26;">
            <Label text="👥  Administration" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f1623; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Label text="Manage all registered accounts and review pending requests." style="-fx-font-size: 13px; -fx-text-fill: #6b7280; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        </VBox>

        <HBox spacing="10" style="-fx-padding: 18 26 0 26; -fx-background-color: white;">
            <Button fx:id="tabUsers" text="User Accounts" onAction="#showUsersTab" style="-fx-background-color: #e8550a; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6; -fx-padding: 8 16; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            <Button fx:id="tabRequests" text="Pending Requests" onAction="#showRequestsTab" style="-fx-background-color: #f3f4f6; -fx-text-fill: #374151; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6; -fx-padding: 8 16; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        </HBox>

        <StackPane VBox.vgrow="ALWAYS" style="-fx-padding: 14 26 0 26; -fx-background-color: white;">

            <VBox fx:id="usersContainer" spacing="0">
                <TableView fx:id="userTable" VBox.vgrow="ALWAYS" style="-fx-border-color: #e2e5ea; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;">
                    <columns>
                        <TableColumn fx:id="idCol"       text="ID"       prefWidth="60"/>
                        <TableColumn fx:id="usernameCol" text="Username" prefWidth="250"/>
                        <TableColumn fx:id="roleCol"     text="Role"     prefWidth="150"/>
                    </columns>
                    <placeholder>
                        <Label text="No users found." style="-fx-text-fill: #9ca3af; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                    </placeholder>
                </TableView>

                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #fafbfc; -fx-border-color: #e2e5ea; -fx-border-width: 1 0 0 0; -fx-padding: 12 0 12 0;">
                    <Label fx:id="userCountLabel" text="0 users" style="-fx-font-size: 13px; -fx-text-fill: #6b7280; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Delete User" onAction="#handleDeleteUser" style="-fx-background-color: transparent; -fx-text-fill: #dc2626; -fx-border-color: #dc2626; -fx-border-radius: 6; -fx-cursor: hand; -fx-font-size: 13px; -fx-padding: 7 14; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                    <Button text="Edit User" onAction="#handleEditUser" style="-fx-background-color: #e8550a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 13px; -fx-padding: 8 18; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                </HBox>
            </VBox>

            <VBox fx:id="requestsContainer" spacing="0" visible="false" managed="false">
                <TableView fx:id="requestTable" VBox.vgrow="ALWAYS" style="-fx-border-color: #e2e5ea; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;">
                    <columns>
                        <TableColumn fx:id="reqIdCol" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="reqUsernameCol" text="Username" prefWidth="150"/>
                        <TableColumn fx:id="reqTypeCol" text="Type" prefWidth="180"/>
                        <TableColumn fx:id="reqDetailsCol" text="Details" prefWidth="250"/>
                        <TableColumn fx:id="reqStatusCol" text="Status" prefWidth="120"/>
                    </columns>
                    <placeholder>
                        <Label text="No pending requests." style="-fx-text-fill: #9ca3af; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                    </placeholder>
                </TableView>

                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #fafbfc; -fx-border-color: #e2e5ea; -fx-border-width: 1 0 0 0; -fx-padding: 12 0 12 0;">
                    <Label fx:id="requestCountLabel" text="0 requests" style="-fx-font-size: 13px; -fx-text-fill: #6b7280; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Reject" onAction="#handleRejectRequest" style="-fx-background-color: white; -fx-text-fill: #dc2626; -fx-border-color: #dc2626; -fx-border-radius: 6; -fx-cursor: hand; -fx-font-size: 13px; -fx-padding: 7 14; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                    <Button text="Approve" onAction="#handleApproveRequest" style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 13px; -fx-padding: 8 18; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
                </HBox>
            </VBox>

        </StackPane>
    </VBox>

    <StackPane fx:id="editUserOverlay" visible="false" managed="false" style="-fx-background-color: rgba(15, 22, 35, 0.65);">
        <VBox maxWidth="360" spacing="16" StackPane.alignment="CENTER"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 28; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 25, 0, 0, 10);">

            <Label text="Edit User Details" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f1623; -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>

            <VBox spacing="4">
                <Label text="Username" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TextField fx:id="editUsernameField" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-padding: 8; -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Role" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <ComboBox fx:id="editRoleCombo" maxWidth="Infinity" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-padding: 4; -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="New Password (Optional)" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <TextField fx:id="editPasswordField" promptText="Leave blank to keep current" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-padding: 8; -fx-font-size: 13px;"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Cancel" onAction="#closeEditOverlay" style="-fx-background-color: white; -fx-text-fill: #374151; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 8 16;"/>
                <Button text="Save Changes" onAction="#saveUserEdit" style="-fx-background-color: #e8550a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 16;"/>
            </HBox>
        </VBox>
    </StackPane>

</StackPane>