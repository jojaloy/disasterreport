<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.disasterreport.controller.ManageUsersController"
      spacing="0"
      style="-fx-background-color: #f0f2f5;">

    <!-- Header -->
    <VBox style="-fx-background-color: white; -fx-border-color: #dde1e7;
                 -fx-border-width: 0 0 1 0; -fx-padding: 16 24 16 24;">
        <Label text="👥 Manage Users"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a2a4a;"/>
        <Label text="Admin only — view and manage all registered accounts."
               style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
    </VBox>

    <!-- Table -->
    <VBox VBox.vgrow="ALWAYS" spacing="0"
          style="-fx-background-color: white; -fx-padding: 16 24 16 24;">
        <TableView fx:id="userTable" VBox.vgrow="ALWAYS"
                   style="-fx-border-color: #dde1e7; -fx-border-radius: 6; -fx-background-radius: 6;">
            <columns>
                <TableColumn fx:id="idCol"       text="ID"       prefWidth="60"/>
                <TableColumn fx:id="usernameCol" text="Username" prefWidth="180"/>
                <TableColumn fx:id="roleCol"     text="Role"     prefWidth="130"/>
            </columns>
            <placeholder>
                <Label text="No users found."
                       style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;"/>
            </placeholder>
        </TableView>
    </VBox>

    <!-- Bottom bar -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: #f7f8fa; -fx-border-color: #dde1e7;
                 -fx-border-width: 1 0 0 0; -fx-padding: 10 24 10 24;">
        <Label fx:id="countLabel"
               text="0 users"
               style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="roleChangeCombo"
                  promptText="Change role to…"
                  prefWidth="160"
                  style="-fx-font-size: 13px;"/>
        <Button text="Apply Role Change"
                onAction="#handleChangeRole"
                style="-fx-background-color: #1a2a4a; -fx-text-fill: white;
                       -fx-background-radius: 5; -fx-cursor: hand;
                       -fx-font-size: 13px; -fx-padding: 7 16 7 16;"/>
        <Button text="Refresh"
                onAction="#handleRefresh"
                style="-fx-background-color: transparent; -fx-text-fill: #1a2a4a;
                       -fx-border-color: #1a2a4a; -fx-border-radius: 5;
                       -fx-background-radius: 5; -fx-cursor: hand;
                       -fx-font-size: 13px; -fx-padding: 7 14 7 14;"/>
    </HBox>

</VBox>
