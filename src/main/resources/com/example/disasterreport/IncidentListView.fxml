<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    IncidentListView.fxml — Updated color scheme:
    White background, #0f1623 header text, #e8550a primary buttons
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.disasterreport.controller.IncidentListController"
      spacing="0"
      style="-fx-background-color: white;">

    <!-- Header -->
    <VBox style="-fx-background-color: white;
                 -fx-border-color: #e2e5ea;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 18 26 18 26;">
        <Label text="Incident List"
               style="-fx-font-size: 20px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #0f1623;
                      -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        <Label text="Browse, search, and manage all reported incidents."
               style="-fx-font-size: 13px;
                      -fx-text-fill: #6b7280;
                      -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
    </VBox>

    <!-- Filter Bar -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: #fafbfc;
                 -fx-border-color: #e2e5ea;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 12 26 12 26;">
        <TextField fx:id="searchField"
                   promptText="Search by location or type..."
                   prefWidth="220"
                   style="-fx-background-color: white;
                          -fx-border-color: #d1d5db;
                          -fx-border-radius: 6;
                          -fx-background-radius: 6;
                          -fx-padding: 8 12 8 12;
                          -fx-font-size: 13px;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        <ComboBox fx:id="typeFilterCombo"
                  promptText="Type"
                  prefWidth="130"
                  onAction="#handleFilter"
                  style="-fx-font-size: 13px;
                         -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        <ComboBox fx:id="statusFilterCombo"
                  promptText="Status"
                  prefWidth="130"
                  onAction="#handleFilter"
                  style="-fx-font-size: 13px;
                         -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        <!-- Primary action: orange-red -->
        <Button text="Search" onAction="#handleSearch"
                style="-fx-background-color: #e8550a;
                       -fx-text-fill: white;
                       -fx-background-radius: 6;
                       -fx-cursor: hand;
                       -fx-font-size: 13px;
                       -fx-font-weight: bold;
                       -fx-padding: 8 18 8 18;
                       -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        <!-- Secondary: outlined dark navy -->
        <Button text="Clear Filters" onAction="#handleClearFilters"
                style="-fx-background-color: white;
                       -fx-text-fill: #374151;
                       -fx-border-color: #d1d5db;
                       -fx-border-radius: 6;
                       -fx-background-radius: 6;
                       -fx-cursor: hand;
                       -fx-font-size: 13px;
                       -fx-padding: 8 16 8 16;
                       -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="↻  Refresh" onAction="#handleRefresh"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #0f1623;
                       -fx-border-color: #0f1623;
                       -fx-border-radius: 6;
                       -fx-background-radius: 6;
                       -fx-cursor: hand;
                       -fx-font-size: 13px;
                       -fx-padding: 8 14 8 14;
                       -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
    </HBox>

    <!-- Table -->
    <VBox VBox.vgrow="ALWAYS" spacing="0"
          style="-fx-background-color: white; -fx-padding: 18 26 0 26;">
        <TableView fx:id="incidentTable" VBox.vgrow="ALWAYS"
                   style="-fx-border-color: #e2e5ea;
                          -fx-border-radius: 8;
                          -fx-background-radius: 8;
                          -fx-font-family: 'Segoe UI', 'Arial', sans-serif;">
            <columns>
                <TableColumn fx:id="idColumn"         text="#"           prefWidth="50"/>
                <TableColumn fx:id="typeColumn"       text="Type"        prefWidth="110"/>
                <TableColumn fx:id="locationColumn"   text="Location"    prefWidth="170"/>
                <TableColumn fx:id="dateColumn"       text="Date"        prefWidth="110"/>
                <TableColumn fx:id="statusColumn"     text="Status"      prefWidth="110"/>
                <TableColumn fx:id="reportedByColumn" text="Reported By" prefWidth="140"/>
            </columns>
            <placeholder>
                <Label text="No incidents found."
                       style="-fx-text-fill: #9ca3af;
                              -fx-font-size: 13px;
                              -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
            </placeholder>
        </TableView>
    </VBox>

    <!-- Bottom Action Bar -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: #fafbfc;
                 -fx-border-color: #e2e5ea;
                 -fx-border-width: 1 0 0 0;
                 -fx-padding: 12 26 12 26;">
        <Label fx:id="recordCountLabel"
               text="0 incidents"
               style="-fx-font-size: 13px;
                      -fx-text-fill: #6b7280;
                      -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="viewDetailsButton"
                text="View Details"
                onAction="#handleViewDetails"
                style="-fx-background-color: white;
                       -fx-text-fill: #374151;
                       -fx-border-color: #d1d5db;
                       -fx-border-radius: 6;
                       -fx-background-radius: 6;
                       -fx-cursor: hand;
                       -fx-font-size: 13px;
                       -fx-padding: 8 18 8 18;
                       -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        <!-- Primary CTA — orange-red -->
        <Button fx:id="updateStatusButton"
                text="Update Status"
                onAction="#handleUpdateStatus"
                style="-fx-background-color: #e8550a;
                       -fx-text-fill: white;
                       -fx-background-radius: 6;
                       -fx-cursor: hand;
                       -fx-font-size: 13px;
                       -fx-font-weight: bold;
                       -fx-padding: 8 18 8 18;
                       -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
    </HBox>

</VBox>
