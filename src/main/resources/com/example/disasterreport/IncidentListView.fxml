<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.disasterreport.controller.IncidentListController"
      spacing="0"
      style="-fx-background-color: #f0f2f5;">

    <!-- Header -->
    <VBox style="-fx-background-color: white; -fx-border-color: #dde1e7;
                 -fx-border-width: 0 0 1 0; -fx-padding: 16 24 16 24;">
        <Label text="Incident List"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a2a4a;"/>
        <Label text="Browse, search, and manage all reported incidents."
               style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
    </VBox>

    <!-- Filter Bar -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-border-color: #dde1e7;
                 -fx-border-width: 0 0 1 0; -fx-padding: 12 24 12 24;">
        <TextField fx:id="searchField"
                   promptText="Search by location or type..."
                   prefWidth="220"
                   style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db;
                          -fx-border-radius: 5; -fx-background-radius: 5;
                          -fx-padding: 7 12 7 12; -fx-font-size: 13px;"/>
        <ComboBox fx:id="typeFilterCombo"
                  promptText="Type"
                  prefWidth="130"
                  onAction="#handleFilter"
                  style="-fx-font-size: 13px;"/>
        <ComboBox fx:id="statusFilterCombo"
                  promptText="Status"
                  prefWidth="130"
                  onAction="#handleFilter"
                  style="-fx-font-size: 13px;"/>
        <Button text="Search" onAction="#handleSearch"
                style="-fx-background-color: #1a2a4a; -fx-text-fill: white;
                       -fx-background-radius: 5; -fx-cursor: hand;
                       -fx-font-size: 13px; -fx-padding: 7 16 7 16;"/>
        <Button text="Clear Filters" onAction="#handleClearFilters"
                style="-fx-background-color: #f3f4f6; -fx-text-fill: #374151;
                       -fx-border-color: #d1d5db; -fx-border-radius: 5;
                       -fx-background-radius: 5; -fx-cursor: hand;
                       -fx-font-size: 13px; -fx-padding: 7 16 7 16;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#handleRefresh"
                style="-fx-background-color: transparent; -fx-text-fill: #1a2a4a;
                       -fx-border-color: #1a2a4a; -fx-border-radius: 5;
                       -fx-background-radius: 5; -fx-cursor: hand;
                       -fx-font-size: 13px; -fx-padding: 7 14 7 14;"/>
    </HBox>

    <!-- Table -->
    <VBox VBox.vgrow="ALWAYS" spacing="0"
          style="-fx-background-color: white; -fx-padding: 16 24 16 24;">
        <TableView fx:id="incidentTable" VBox.vgrow="ALWAYS"
                   style="-fx-border-color: #dde1e7; -fx-border-radius: 6;
                          -fx-background-radius: 6;">
            <columns>
                <TableColumn fx:id="idColumn"         text="#"           prefWidth="50"/>
                <TableColumn fx:id="typeColumn"       text="Type"        prefWidth="110"/>
                <TableColumn fx:id="locationColumn"   text="Location"    prefWidth="160"/>
                <TableColumn fx:id="dateColumn"       text="Date"        prefWidth="110"/>
                <TableColumn fx:id="statusColumn"     text="Status"      prefWidth="100"/>
                <TableColumn fx:id="reportedByColumn" text="Reported By" prefWidth="130"/>
            </columns>
            <placeholder>
                <Label text="No incidents found."
                       style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;"/>
            </placeholder>
        </TableView>
    </VBox>

    <!-- Bottom Action Bar -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: #f7f8fa; -fx-border-color: #dde1e7;
                 -fx-border-width: 1 0 0 0; -fx-padding: 10 24 10 24;">
        <Label fx:id="recordCountLabel"
               text="0 incidents"
               style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="viewDetailsButton"
                text="View Details"
                onAction="#handleViewDetails"
                style="-fx-background-color: #f3f4f6; -fx-text-fill: #374151;
                       -fx-border-color: #d1d5db; -fx-border-radius: 5;
                       -fx-background-radius: 5; -fx-cursor: hand;
                       -fx-font-size: 13px; -fx-padding: 7 16 7 16;"/>
        <Button fx:id="updateStatusButton"
                text="Update Status"
                onAction="#handleUpdateStatus"
                style="-fx-background-color: #1a2a4a; -fx-text-fill: white;
                       -fx-background-radius: 5; -fx-cursor: hand;
                       -fx-font-size: 13px; -fx-padding: 7 16 7 16;"/>
    </HBox>

</VBox>
