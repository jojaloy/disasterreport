<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<!--
    MapView.fxml
    ─────────────────────────────────────────────────────────────────────────
    The WebView is set to fill ALL available space (VBox.vgrow + HBox.hgrow
    + maxWidth/maxHeight = MAX_VALUE).  This prevents the Leaflet canvas from
    being clipped into tiles when the window is resized or zoomed.
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.disasterreport.controller.MapViewController"
      spacing="0"
      style="-fx-background-color: #f0f2f5;">

    <!-- Header -->
    <VBox style="-fx-background-color: white;
                 -fx-border-color: #dde1e7;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 16 24 16 24;">
        <Label text="Map View"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a2a4a;"/>
        <Label text="Live map of all reported incidents."
               style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
    </VBox>

    <!-- Filter / control bar -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: white;
                 -fx-border-color: #dde1e7;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 10 24 10 24;">
        <ComboBox fx:id="typeFilterCombo"
                  promptText="Filter by type"
                  prefWidth="160"
                  onAction="#handleFilter"
                  style="-fx-font-size: 13px;"/>
        <Button text="Show All" onAction="#handleShowAll"
                style="-fx-background-color: #1a2a4a; -fx-text-fill: white;
                       -fx-background-radius: 5; -fx-cursor: hand;
                       -fx-font-size: 13px; -fx-padding: 7 16 7 16;"/>
        <Button text="Refresh" onAction="#handleRefresh"
                style="-fx-background-color: transparent; -fx-text-fill: #1a2a4a;
                       -fx-border-color: #1a2a4a; -fx-border-radius: 5;
                       -fx-background-radius: 5; -fx-cursor: hand;
                       -fx-font-size: 13px; -fx-padding: 7 14 7 14;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="markerCountLabel"
               text="0 markers"
               style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
    </HBox>

    <!--
        WebView wrapper
        ───────────────
        The StackPane lets the WebView stretch to fill every pixel.
        VBox.vgrow="ALWAYS"  → takes all remaining vertical space in the VBox.
        maxWidth / maxHeight → overrides JavaFX default of USE_PREF_SIZE so the
                               node actually expands when the window grows.
    -->
    <StackPane VBox.vgrow="ALWAYS"
               maxWidth="Infinity"
               maxHeight="Infinity">
        <WebView fx:id="mapWebView"
                 maxWidth="Infinity"
                 maxHeight="Infinity"/>
    </StackPane>

    <!-- Status bar -->
    <HBox style="-fx-background-color: #f7f8fa;
                 -fx-border-color: #dde1e7;
                 -fx-border-width: 1 0 0 0;
                 -fx-padding: 6 24 6 24;">
        <Label fx:id="statusLabel"
               text="Loading map…"
               style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
    </HBox>

</VBox>
