<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.disasterreport.controller.MapViewController"
      spacing="0"
      style="-fx-background-color: #111e2e;">

    <!-- Header -->
    <VBox style="-fx-background-color: #142033;
                 -fx-border-color: #1e3a5f;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 20 26 18 26;">
        <Label text="Live Incident Map"
               style="-fx-font-size: 20px; -fx-font-weight: bold;
                      -fx-text-fill: #f0f9ff; -fx-font-family: 'Segoe UI';"/>
        <Label text="Geographic view of all reported disaster incidents."
               style="-fx-font-size: 13px; -fx-text-fill: #64748b;
                      -fx-font-family: 'Segoe UI'; -fx-padding: 4 0 0 0;"/>
    </VBox>

    <!-- Filter / control bar -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: #1a2f45;
                 -fx-border-color: #1e3a5f;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 11 26 11 26;">
        <ComboBox fx:id="typeFilterCombo"
                  promptText="Filter by type"
                  prefWidth="160"
                  onAction="#handleFilter"
                  style="-fx-background-color: #0f2233;
                         -fx-border-color: #1e3a5f;
                         -fx-border-radius: 7; -fx-background-radius: 7;
                         -fx-font-size: 13px; -fx-font-family: 'Segoe UI';"/>
        <Button text="Show All" onAction="#handleShowAll"
                style="-fx-background-color: #0ea5e9;
                       -fx-text-fill: #0d1b2a;
                       -fx-background-radius: 7; -fx-cursor: hand;
                       -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-font-family: 'Segoe UI';
                       -fx-padding: 8 16 8 16;"/>
        <Button text="↻  Refresh" onAction="#handleRefresh"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #38bdf8;
                       -fx-border-color: #38bdf8;
                       -fx-border-radius: 7; -fx-background-radius: 7;
                       -fx-cursor: hand; -fx-font-size: 13px;
                       -fx-font-family: 'Segoe UI';
                       -fx-padding: 8 14 8 14;"/>

        <!-- Colour legend -->
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="12" alignment="CENTER">
            <Label text="🌊 Flood"    style="-fx-font-size: 11px; -fx-text-fill: #93c5fd; -fx-font-family: 'Segoe UI';"/>
            <Label text="🔥 Fire"     style="-fx-font-size: 11px; -fx-text-fill: #fca5a5; -fx-font-family: 'Segoe UI';"/>
            <Label text="🪨 Quake"   style="-fx-font-size: 11px; -fx-text-fill: #fdba74; -fx-font-family: 'Segoe UI';"/>
            <Label text="🌀 Typhoon" style="-fx-font-size: 11px; -fx-text-fill: #c4b5fd; -fx-font-family: 'Segoe UI';"/>
            <Label text="⛰ Slide"    style="-fx-font-size: 11px; -fx-text-fill: #d6b86a; -fx-font-family: 'Segoe UI';"/>
        </HBox>
        <Region minWidth="10"/>
        <Label fx:id="markerCountLabel"
               text="0 markers"
               style="-fx-font-size: 12px; -fx-text-fill: #64748b;
                      -fx-font-family: 'Segoe UI';"/>
    </HBox>

    <!-- WebView map — fills all remaining space -->
    <StackPane VBox.vgrow="ALWAYS"
               maxWidth="Infinity"
               maxHeight="Infinity">
        <WebView fx:id="mapWebView"
                 maxWidth="Infinity"
                 maxHeight="Infinity"/>
    </StackPane>

    <!-- Status bar -->
    <HBox style="-fx-background-color: #0a1628;
                 -fx-border-color: #1e3a5f;
                 -fx-border-width: 1 0 0 0;
                 -fx-padding: 6 26 6 26;"
          alignment="CENTER_LEFT" spacing="8">
        <Label text="●" style="-fx-text-fill: #38bdf8; -fx-font-size: 9px;"/>
        <Label fx:id="statusLabel"
               text="Loading map…"
               style="-fx-font-size: 12px; -fx-text-fill: #475569;
                      -fx-font-family: 'Segoe UI';"/>
    </HBox>

</VBox>
