<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<!--
    MapView.fxml — Updated color scheme:
    White background, #0f1623 text, #e8550a primary buttons
    WebView still fills all available space (VBox.vgrow + maxWidth/Height = MAX_VALUE)
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.disasterreport.controller.MapViewController"
      spacing="0"
      style="-fx-background-color: white;">

    <!-- Header -->
    <VBox style="-fx-background-color: white;
                 -fx-border-color: #e2e5ea;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 18 26 18 26;">
        <Label text="Map View"
               style="-fx-font-size: 20px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #0f1623;
                      -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        <Label text="Live map of all reported incidents."
               style="-fx-font-size: 13px;
                      -fx-text-fill: #6b7280;
                      -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
    </VBox>

    <!-- Filter / control bar -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: #fafbfc;
                 -fx-border-color: #e2e5ea;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 11 26 11 26;">
        <ComboBox fx:id="typeFilterCombo"
                  promptText="Filter by type"
                  prefWidth="160"
                  onAction="#handleFilter"
                  style="-fx-font-size: 13px;
                         -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        <!-- Primary: orange-red -->
        <Button text="Show All" onAction="#handleShowAll"
                style="-fx-background-color: #e8550a;
                       -fx-text-fill: white;
                       -fx-background-radius: 6;
                       -fx-cursor: hand;
                       -fx-font-size: 13px;
                       -fx-font-weight: bold;
                       -fx-padding: 8 18 8 18;
                       -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        <!-- Secondary: outlined navy -->
        <Button text="↻  Refresh" onAction="#handleRefresh"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #0f1623;
                       -fx-border-color: #0f1623;
                       -fx-border-radius: 6;
                       -fx-background-radius: 6;
                       -fx-cursor: hand;
                       -fx-font-size: 13px;
                       -fx-padding: 8 14 8 14;
                       -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="markerCountLabel"
               text="0 markers"
               style="-fx-font-size: 13px;
                      -fx-text-fill: #6b7280;
                      -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
    </HBox>

    <!--
        WebView wrapper — unchanged sizing logic:
        VBox.vgrow="ALWAYS" + maxWidth/maxHeight="Infinity" prevents tile fragmentation.
    -->
    <StackPane VBox.vgrow="ALWAYS"
               maxWidth="Infinity"
               maxHeight="Infinity">
        <WebView fx:id="mapWebView"
                 maxWidth="Infinity"
                 maxHeight="Infinity"/>
    </StackPane>

    <!-- Status bar -->
    <HBox style="-fx-background-color: #f4f5f7;
                 -fx-border-color: #e2e5ea;
                 -fx-border-width: 1 0 0 0;
                 -fx-padding: 6 26 6 26;">
        <Label fx:id="statusLabel"
               text="Loading map…"
               style="-fx-font-size: 12px;
                      -fx-text-fill: #6b7280;
                      -fx-font-family: 'Segoe UI', 'Arial', sans-serif;"/>
    </HBox>

</VBox>
